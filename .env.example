LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_API_KEY=your_api_key_here

LLM_MODEL_STAGE1=openai/gpt-5-nano
LLM_MODEL_STAGE2=openai/gpt-5-mini

CHUNK_SIZE_CHARS=18000

LLM_TEMPERATURE_STAGE1=0.1
LLM_TEMPERATURE_STAGE2=0.1

LLM_MAX_OUTPUT_TOKENS_STAGE1=4000
LLM_MAX_OUTPUT_TOKENS_STAGE2=4000

LOG_LEVEL=INFO

INPUT_DIR=./input
OUTPUT_DIR=./output
PROCESSED_DIR=./processed
FAILED_DIR=./failed