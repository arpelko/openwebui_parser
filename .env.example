LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_API_KEY=your_api_key_here

# Käytä jompaakumpaa:
LLM_MODEL=openai/gpt-5-mini
# LLM_MODEL=openai/gpt-5-nano

CHUNK_SIZE_CHARS=18000
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=4000
LOG_LEVEL=INFO

INPUT_DIR=./input
OUTPUT_DIR=./output
PROCESSED_DIR=./processed
FAILED_DIR=./failed